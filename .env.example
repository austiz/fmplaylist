APP_NAME="FM Playlist"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no server needed)
DB_CONNECTION=sqlite

# MySQL (production / Namecheap)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=fmplaylist
# DB_USERNAME=root
# DB_PASSWORD=

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Required in production (HTTPS only):
# SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── Queue / Cache / Storage ────────────────────────────────────────────────────
# Use sync on shared hosting (no queue worker available)
QUEUE_CONNECTION=sync
CACHE_STORE=database
FILESYSTEM_DISK=public
BROADCAST_CONNECTION=log

# ── Mail (optional — not used by the app, keep for Laravel defaults) ───────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@fmplaylist.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
